//import necessary packages for event handling, drawing, and data structures
import java.awt.event.*;
import java.awt.*;
import java.util.*;
import javax.swing.JComponent;

//custom component class for mouse and keyboard interactions
//extends JComponent to create a custom GUI component
//implements MouseListener and KeyListener interfaces  to handle mouse and keyboard events
public class MyComponent extends JComponent implements MouseListener, KeyListener {
    //map to store counts of clicks in each quadrant
    //key: quadrant number (1, 2, 3, 4)
    //value: count of clicks in that quadrant
    private Map<Integer, Integer> quadrantCounts;

    //constructor to initialize the component
    public MyComponent() {
        //initialize the quadrantCounts map
        quadrantCounts = new HashMap<>();
        //adding mouse listener to handle mouse events
        addMouseListener(this);
        //adding key listener to handle keyboard events
        addKeyListener(this);
        //ensures component can receive focus for key events
        setFocusable(true);
    }

    //method to determine the quadrant based on mouse click coordinates
    private int getQuadrant(int x, int y) {
        //get the width and the height of the component
        int w = getWidth();
        int h = getHeight();
        //determine the quadrant based on the mouse coordinates
        if (x < w / 2) {
            //if x coordinate is less than half the width
            if (y < h / 2) {
                //if the y coordinate is less than half the height
                //mouse click is in quadrant 1
                return 1;
            } else {
                //if y coordinate is greater than or equal to half the height
                //mouse click is in quadrant 4
                return 4;
            }
        } else {
            //if x coordinate is greater than or equal to half the height
            if (y < h / 2) {
                //if y coordinate is less than half the height
                //mouse click is in quadrant 2
                return 2;
            } else {
                //if y coordinate is greater than or equal to half the height
                //mouse click is in quadrant 3
                return 3;
            }
        }
    }

    //To make it clearer to debug/ so I know where I am clicking
    //method to draw the component
    //overrides the paintComponent method of JComponent
    @Override
    protected void paintComponent(Graphics g) {
        //call the superclass's paintComponent method to perform default painting
        super.paintComponent(g);
        //get the width and height of the component
        int w = getWidth();
        int h = getHeight();

        //draw lines to divide the component into quadrants
        g.setColor(Color.BLUE);
        //draw horizontal line at the middle of the component
        g.drawLine(0, h / 2, w, h / 2);
        //draw vertical line at the middle of the component
        g.drawLine(w / 2, 0, w / 2, h);

        //draw quadrant numbers for reference
        g.setColor(Color.BLACK);
        //draw quadrant number 1 in the top left quadrant
        g.drawString("1", w / 4, h / 4);
        //draw quadrant number 2 in the top right quadrant
        g.drawString("2", w * 3 / 4, h / 4);
        //draw quadrant number 3 in the bottom right quadrant
        g.drawString("3", w * 3 / 4, h * 3 / 4);
        //draw quadrant number 4 in the bottom left quadrant
        g.drawString("4", w / 4, h * 3 / 4);
    }

    //method to get the preferred size of the component
    //overrides the getPreferredSize method of the JComponent
    @Override
    public Dimension getPreferredSize() {
        //specify the preferred size of the component
        //set the width and height to 400 pixels
        return new Dimension(400, 400);
    }

    //mouse event handler for mouse click events
    //implements the mouseClicked method of the MouseListener interface
    @Override
    public void mouseClicked(MouseEvent e) {
        //get the quadrant where the mouse click occurred
        int quadrant = getQuadrant(e.getX(), e.getY());
        //increment the count of clicks in the respective quadrant
        //if the quadrant key doesn't exist, initialize its count to 0 and then increment
        quadrantCounts.put(quadrant, quadrantCounts.getOrDefault(quadrant, 0) + 1);
        //print the updated quadrant counts
        System.out.println(quadrantCounts);
    }

    //unused mouse event handlers
    //required to be implemented by the MOuseListener interface
    @Override
    public void mousePressed(MouseEvent e) {}

    @Override
    public void mouseReleased(MouseEvent e) {}

    @Override
    public void mouseEntered(MouseEvent e) {}

    @Override
    public void mouseExited(MouseEvent e) {}

    //handle key presses to record quadrant of the mouse pointer
    //key event handler for the key press events
    //implements the keyPressed method of the KeyListener interface
    @Override
    public void keyPressed(KeyEvent e) {
        //get the quadrant where the mouse pointer is located
        int quadrant = getQuadrant(getMousePosition().x, getMousePosition().y);
        //increment the count of clicks in the respective quadrant
        //if the quadrant key does not exist, initialize its count to 0 then increment
        quadrantCounts.put(quadrant, quadrantCounts.getOrDefault(quadrant, 0) + 1);
        //printing the updated quadrant counts
        System.out.println(quadrantCounts);
    }

    //unused key event handlers
    //required to be implemented by the KeyListener interface
    @Override
    public void keyTyped(KeyEvent e) {}

    @Override
    public void keyReleased(KeyEvent e) {}
}